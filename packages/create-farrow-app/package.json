{
  "name": "create-farrow-app",
  "version": "2.1.0",
  "description": "A cli-tools for scaffolding farrow project",
  "main": "dist/index.js",
  "homepage": "https://www.farrowjs.com/",
  "bin": {
    "create-farrow-app": "./bin/scripts.js"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts --target esnext --format cjs --outDir dist --dts false && tsdown --config tsdown.config.ts --target esnext --format esm --outDir dist/esm --dts false",
    "build:dist": "pnpm run build",
    "build:esm": "pnpm run build"
  },
  "keywords": [
    "Web Framework",
    "TypeScript",
    "Functional Programming"
  ],
  "author": "Jade Gu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farrow-js/farrow.git"
  },
  "dependencies": {
    "enquirer": "^2.3.6",
    "kolorist": "^1.2.9",
    "minimist": "^1.2.5",
    "tslib": "^2.5.0",
    "yargs": "^15.3.1"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.2",
    "typescript": "^5.0.4"
  },
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts"
}
