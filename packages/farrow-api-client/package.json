{
  "name": "farrow-api-client",
  "version": "2.3.0",
  "description": "A type-friendly BFF framework",
  "main": "dist/index.js",
  "homepage": "https://www.farrowjs.com/",
  "scripts": {
    "build": "tsdown --config tsdown.config.ts --target esnext --format cjs --outDir dist --dts false && tsdown --config tsdown.config.ts --target esnext --format esm --outDir dist/esm --dts false",
    "test": "vitest run --config vitest.config.js",
    "test:coverage": "vitest run --config vitest.config.js --coverage",
    "build:dist": "pnpm run build",
    "build:esm": "pnpm run build"
  },
  "files": [
    "src",
    "dist"
  ],
  "keywords": [
    "Web Framework",
    "TypeScript",
    "Functional Programming"
  ],
  "author": "Jade Gu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farrow-js/farrow.git"
  },
  "devDependencies": {
    "@types/node-fetch": "^2.5.8",
    "farrow-api": "workspace:^2.3.0",
    "farrow-api-server": "workspace:^2.3.0",
    "farrow-http": "workspace:^2.3.0",
    "farrow-schema": "workspace:^2.3.0",
    "node-fetch": "2",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "isomorphic-unfetch": "^3.1.0",
    "tslib": "^2.5.0"
  },
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts"
}
