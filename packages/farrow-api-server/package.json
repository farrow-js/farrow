{
  "name": "farrow-api-server",
  "version": "2.3.0",
  "description": "A type-friendly BFF framework",
  "main": "dist/index.js",
  "homepage": "https://www.farrowjs.com/",
  "scripts": {
    "build": "tsdown --config tsdown.config.ts --target esnext --format cjs --outDir dist --dts false && tsdown --config tsdown.config.ts --target esnext --format esm --outDir dist/esm --dts false",
    "test": "jest",
    "test:coverage": "jest --collectCoverage --coverage",
    "build:dist": "pnpm run build",
    "build:esm": "pnpm run build"
  },
  "files": [
    "src",
    "dist"
  ],
  "keywords": [
    "Web Framework",
    "TypeScript",
    "Functional Programming"
  ],
  "author": "Jade Gu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farrow-js/farrow.git"
  },
  "devDependencies": {
    "@types/jest": "^29.5.1",
    "@types/lodash.get": "^4.4.6",
    "@types/node-fetch": "^2.5.8",
    "@types/supertest": "^2.0.10",
    "farrow-api-client": "workspace:^2.3.0",
    "jest": "^29.5.0",
    "node-fetch": "^2.6.9",
    "supertest": "^6.1.6",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "farrow-api": "workspace:^2.3.1",
    "farrow-http": "workspace:^2.3.1",
    "farrow-schema": "workspace:^2.3.3",
    "lodash.get": "^4.4.2",
    "tslib": "^2.5.0"
  },
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts"
}
