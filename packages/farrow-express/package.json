{
  "name": "farrow-express",
  "version": "2.3.0",
  "description": "A Type-Friendly Web Framework",
  "main": "dist/index.js",
  "homepage": "https://www.farrowjs.com/",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown --config tsdown.config.ts --target esnext --format cjs --outDir dist --dts false && tsdown --config tsdown.config.ts --target esnext --format esm --outDir dist/esm --dts false",
    "test": "vitest run --config vitest.config.js",
    "test:coverage": "vitest run --config vitest.config.js --coverage",
    "build:dist": "pnpm run build",
    "build:esm": "pnpm run build"
  },
  "keywords": [
    "Web Framework",
    "TypeScript",
    "Functional Programming"
  ],
  "author": "Jade Gu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farrow-js/farrow.git"
  },
  "peerDependencies": {
    "express": "^4.17.1",
    "farrow-http": "workspace:^2.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.16",
    "@types/supertest": "^2.0.12",
    "express": "^4.17.1",
    "farrow-http": "workspace:^2.3.1",
    "farrow-pipeline": "workspace:^2.3.0",
    "farrow-schema": "workspace:^2.3.3",
    "supertest": "^6.1.6",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "tslib": "^2.5.0"
  },
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts"
}
