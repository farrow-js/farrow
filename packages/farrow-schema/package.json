{
  "name": "farrow-schema",
  "version": "2.3.3",
  "description": "A powerful and extensible schema builder",
  "main": "dist/index.js",
  "homepage": "https://www.farrowjs.com/",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "src",
    "dist",
    "validator.d.ts",
    "validator.js",
    "formatter.d.ts",
    "formatter.js"
  ],
  "scripts": {
    "build": "tsdown --config tsdown.config.ts --target esnext --format cjs --outDir dist --dts false && tsdown --config tsdown.config.ts --target esnext --format esm --outDir dist/esm --dts false",
    "build:dist": "pnpm run build",
    "build:esm": "pnpm run build",
    "test:type": "tsc",
    "test": "vitest run --config vitest.config.js",
    "test:coverage": "vitest run --config vitest.config.js --coverage"
  },
  "keywords": [
    "Web Framework",
    "TypeScript",
    "Functional Programming"
  ],
  "author": "Jade Gu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farrow-js/farrow.git"
  },
  "dependencies": {
    "tslib": "^2.5.0"
  },
  "devDependencies": {
    "typescript": "^5.0.4"
  },
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts"
}
