{
  "name": "farrow-vite",
  "version": "2.3.0",
  "description": "Vite adapter for farrow",
  "main": "dist/index.js",
  "homepage": "https://www.farrowjs.com/",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config tsdown.config.ts --target esnext --format cjs --outDir dist --dts false && tsdown --config tsdown.config.ts --target esnext --format esm --outDir dist/esm --dts false",
    "build:dist": "pnpm run build",
    "build:esm": "pnpm run build"
  },
  "keywords": [
    "Web Framework",
    "TypeScript",
    "Functional Programming"
  ],
  "author": "Jade Gu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farrow-js/farrow.git"
  },
  "peerDependencies": {
    "farrow-http": "workspace:^2.3.1",
    "vite": "^2.6.14"
  },
  "devDependencies": {
    "@types/jest": "^29.5.1",
    "@types/supertest": "^2.0.11",
    "farrow-http": "workspace:^2.3.1",
    "jest": "^29.5.0",
    "supertest": "^6.1.6",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.4",
    "vite": "2.6.14"
  },
  "dependencies": {
    "tslib": "^2.5.0"
  },
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts"
}
